# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Multi-Agent AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
# Deployment names must match what you created in Azure AI Studio
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key-here
AZURE_SEARCH_INDEX_NAME=enterprise-docs

# ── Azure Storage (for document ingestion) ────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: sqlite (default), Production: PostgreSQL on Azure
DATABASE_URL=sqlite:///./enterprise_agents.db
# DATABASE_URL=postgresql://pgadmin:PASSWORD@HOST:5432/enterprise_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production (Azure Cache for Redis — TLS required):
# REDIS_URL=rediss://:KEY@YOUR-REDIS.redis.cache.windows.net:6380

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Monitoring (Azure Application Insights) ───────────────────────────────────
AZURE_APP_INSIGHTS_KEY=your-instrumentation-key-here
ENABLE_TELEMETRY=true

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
FINANCE_APPROVAL_THRESHOLD=5000.0
HITL_HIGH_RISK_THRESHOLD=0.85
AGENT_TIMEOUT_SECONDS=120
